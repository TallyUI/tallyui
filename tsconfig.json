{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@tallyui/core": ["packages/core/src/index.ts"],
      "@tallyui/core/*": ["packages/core/src/*"],
      "@tallyui/database": ["packages/database/src/index.ts"],
      "@tallyui/database/*": ["packages/database/src/*"],
      "@tallyui/components": ["packages/components/src/index.ts"],
      "@tallyui/components/*": ["packages/components/src/*"],
      "@tallyui/connector-woocommerce": ["connectors/woocommerce/src/index.ts"],
      "@tallyui/connector-woocommerce/*": ["connectors/woocommerce/src/*"],
      "@tallyui/connector-medusa": ["connectors/medusa/src/index.ts"],
      "@tallyui/connector-medusa/*": ["connectors/medusa/src/*"],
      "@tallyui/connector-shopify": ["connectors/shopify/src/index.ts"],
      "@tallyui/connector-shopify/*": ["connectors/shopify/src/*"],
      "@tallyui/connector-vendure": ["connectors/vendure/src/index.ts"],
      "@tallyui/connector-vendure/*": ["connectors/vendure/src/*"],
      "@tallyui/theme": ["packages/theme/src/index.ts"],
      "@tallyui/theme/*": ["packages/theme/src/*"],
      "@tallyui/storage-sqlite": ["packages/storage-sqlite/src/index.ts"],
      "@tallyui/storage-sqlite/*": ["packages/storage-sqlite/src/*"],
      "@tallyui/primitives": ["packages/primitives/src/index.ts"],
      "@tallyui/primitives/*": ["packages/primitives/src/*"],
      "@tallyui/mock-api": ["apps/mock-api/src/index.ts"],
      "@tallyui/mock-api/*": ["apps/mock-api/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
